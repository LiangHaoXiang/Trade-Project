# ============================================================
# 敏感信息配置模板
# 复制此文件为 .env 并填入真实值：cp .env.example .env
# 注意：.env 文件已被 .gitignore 排除，不会被提交到仓库
# ============================================================

# ---- 数据源 ----
# Tushare 数据接口 Token
# 获取方式：https://tushare.pro/register 注册后在个人主页获取
TUSHARE_TOKEN=your_tushare_token_here

# ---- AI 模型 ----
# 阿里云 DashScope API Key（用于 UI 视觉审核工具）
# 获取方式：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ---- 券商账户（实盘交易时使用）----
# 以下信息仅在实盘模式下需要配置，模拟盘无需填写
# BROKER_ACCOUNT=your_broker_account
# BROKER_PASSWORD=your_broker_password
# BROKER_COMM_PASSWORD=your_comm_password
