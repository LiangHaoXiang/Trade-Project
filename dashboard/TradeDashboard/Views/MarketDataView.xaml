<UserControl x:Class="TradeDashboard.Views.MarketDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:c="clr-namespace:TradeDashboard.Converters">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <c:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <c:FavoriteButtonTextConverter x:Key="FavBtnText"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Favorites + Stock List -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
            <DockPanel>
                <!-- Search Box -->
                <TextBox DockPanel.Dock="Top"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="8,8,8,4"
                         Padding="6,4"
                         Background="#2a2a3e" Foreground="#ccc" BorderBrush="#505070"
                         FontSize="13">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- MA Controls -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="8,4,8,8">
                    <CheckBox Content="MA5" IsChecked="{Binding ShowMA5}" Foreground="#aaa" FontSize="12"/>
                    <CheckBox Content="MA20" IsChecked="{Binding ShowMA20}" Foreground="#aaa" FontSize="12" Margin="10,0,0,0"/>
                </StackPanel>

                <!-- Loading indicator -->
                <ProgressBar DockPanel.Dock="Bottom"
                             IsIndeterminate="{Binding IsLoading}"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                             Height="3" Margin="8,0"/>

                <!-- Tab: 自选 / 全部 -->
                <TabControl SelectedIndex="{Binding LeftTabSelectedIndex}"
                            Background="Transparent" BorderThickness="0" Margin="0,2,0,0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Foreground" Value="#a6adc8"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border x:Name="Bd" Padding="8,4" Background="Transparent" BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                            <ContentPresenter x:Name="Content" ContentSource="Header" HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#2a2a3e"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#89b4fa"/>
                                                <Setter Property="Foreground" Value="#cdd6f4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <!-- 自选 Tab -->
                    <TabItem Header="自选">
                        <Grid>
                            <ListBox x:Name="FavoriteListBox" AllowDrop="True"
                                     ItemsSource="{Binding FavoriteStocks}"
                                     SelectedItem="{Binding SelectedStock}"
                                     Background="Transparent" Foreground="#ccc"
                                     BorderBrush="Transparent"
                                     FontSize="13" Margin="4,2"
                                     VirtualizingStackPanel.IsVirtualizing="True"
                                     VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <ListBox.Resources>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="4,4"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Grid>
                                                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}" Background="Transparent">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding DisplayText}" VerticalAlignment="Center"/>
                                                                <Button Grid.Column="1" Content="✕" FontSize="10"
                                                                        Foreground="#6c7086" Background="Transparent"
                                                                        BorderThickness="0" Padding="4,0" Cursor="Hand"
                                                                        Command="{Binding DataContext.RemoveFromFavoritesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding Symbol}"
                                                                        VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                        <Border x:Name="TopInsert" Height="2" Background="#89b4fa"
                                                                VerticalAlignment="Top" Visibility="Collapsed"/>
                                                        <Border x:Name="BottomInsert" Height="2" Background="#89b4fa"
                                                                VerticalAlignment="Bottom" Visibility="Collapsed"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#2a2a3e"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#3a3a5e"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.Resources>
                            </ListBox>
                            <TextBlock Text="暂无自选股" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#6c7086" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FavoriteStocks.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </TabItem>

                    <!-- 全部 Tab -->
                    <TabItem Header="全部">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ListBox Grid.Row="0" ItemsSource="{Binding FilteredStocks}"
                                     SelectedItem="{Binding SelectedStock}"
                                     Background="Transparent" Foreground="#ccc"
                                     BorderBrush="Transparent"
                                     FontSize="13" Margin="4,2"
                                     VirtualizingStackPanel.IsVirtualizing="True"
                                     VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <ListBox.Resources>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="4,4"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd" Padding="{TemplateBinding Padding}" Background="Transparent">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding DisplayText}" VerticalAlignment="Center"/>
                                                            <Button Grid.Column="1" FontSize="12" FontWeight="Bold"
                                                                    Background="Transparent" BorderThickness="0"
                                                                    Padding="6,0" Cursor="Hand" VerticalAlignment="Center"
                                                                    Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding Symbol}">
                                                                <Button.Content>
                                                                    <MultiBinding Converter="{StaticResource FavBtnText}">
                                                                        <Binding Path="DataContext.FavoriteStocks" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                        <Binding Path="Symbol"/>
                                                                    </MultiBinding>
                                                                </Button.Content>
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Setter Property="Foreground" Value="#6c7086"/>
                                                                        <Style.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter Property="Foreground" Value="#89b4fa"/>
                                                                            </Trigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#2a2a3e"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#3a3a5e"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.Resources>
                            </ListBox>

                            <Button Grid.Row="1" Content="＋ 加自选"
                                    Command="{Binding AddToFavoritesCommand}"
                                    Style="{StaticResource ActionButtonStyle}"
                                    FontSize="12" Padding="4,6" Margin="8,4,8,8"
                                    Visibility="{Binding IsCurrentStockFavorite, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Border>

        <!-- Right Panel: Charts -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="4*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Candlestick Chart -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <sp:WpfPlot x:Name="PricePlot" Background="#1a1a2e"/>
                    <Canvas IsHitTestVisible="False">
                        <Border x:Name="CandleTooltip" Visibility="Collapsed"
                                Background="#2a2a3e" CornerRadius="4" Padding="10,6"
                                BorderBrush="#505070" BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="TipDate" Foreground="White" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/><RowDefinition/><RowDefinition/>
                                        <RowDefinition/><RowDefinition/><RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="开盘" Foreground="#888" FontSize="11"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TipOpen" Foreground="#ccc" FontSize="11" Margin="6,0,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="最高" Foreground="#888" FontSize="11"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TipHigh" Foreground="#ef5350" FontSize="11" Margin="6,0,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="最低" Foreground="#888" FontSize="11"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TipLow" Foreground="#26a69a" FontSize="11" Margin="6,0,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="收盘" Foreground="#888" FontSize="11"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TipClose" Foreground="#ccc" FontSize="11" Margin="6,0,0,0"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="成交量" Foreground="#888" FontSize="11"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TipVolume" Foreground="#ccc" FontSize="11" Margin="6,0,0,0"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="涨跌" Foreground="#888" FontSize="11"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TipChange" Foreground="#ccc" FontSize="11" Margin="6,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Canvas>
                </Grid>
            </Border>

            <!-- Volume Chart -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                <Grid>
                    <sp:WpfPlot x:Name="VolumePlot" Background="#1a1a2e"/>
                    <Canvas IsHitTestVisible="False">
                        <Border x:Name="VolumeTooltip" Visibility="Collapsed"
                                Background="#2a2a3e" CornerRadius="4" Padding="8,4"
                                BorderBrush="#505070" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="VolTipDate" Foreground="#aaa" FontSize="11" Margin="0,0,8,0"/>
                                <TextBlock x:Name="VolTipVolume" Foreground="#ccc" FontSize="11" Margin="0,0,8,0"/>
                                <TextBlock x:Name="VolTipAmount" Foreground="#ccc" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </Canvas>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
