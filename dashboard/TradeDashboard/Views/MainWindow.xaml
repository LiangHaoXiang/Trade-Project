<Window x:Class="TradeDashboard.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="clr-namespace:TradeDashboard.Views"
        Title="交易仪表盘"
    Width="1100" Height="700"
    WindowStartupLocation="CenterScreen"
    Background="#1e1e2e"
    Focusable="True"
    FocusVisualStyle="{x:Null}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#181825" Padding="16,10">
            <DockPanel>
                <TextBlock Text="交易仪表盘" FontSize="18" FontWeight="Bold" Foreground="#cdd6f4" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="刷新" Command="{Binding RefreshCommand}" Margin="0,0,8,0"
                            Style="{StaticResource ActionButtonStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Tabs -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" Margin="0" Padding="0">
            <TabItem Header="总览">
                <v:DashboardView DataContext="{Binding Dashboard}"/>
            </TabItem>
            <TabItem Header="行情">
                <v:MarketDataView DataContext="{Binding MarketData}"/>
            </TabItem>
            <TabItem Header="交易">
                <v:TradingView DataContext="{Binding Trading}"/>
            </TabItem>
            <TabItem Header="交易记录">
                <v:TradeHistoryView DataContext="{Binding TradeHistory}"/>
            </TabItem>
            <TabItem Header="资金曲线">
                <v:EquityCurveView DataContext="{Binding EquityCurve}"/>
            </TabItem>
            <TabItem Header="回测">
                <v:BacktestView DataContext="{Binding Backtest}"/>
            </TabItem>
            <TabItem Header="资讯">
                <v:NewsView DataContext="{Binding News}"/>
            </TabItem>
            <TabItem Header="日志">
                <v:LogViewerView DataContext="{Binding LogViewer}"/>
            </TabItem>
            <TabItem Header="配置">
                <v:ConfigurationView DataContext="{Binding Configuration}"/>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#181825" Padding="12,6">
            <Grid>
                <TextBlock Text="{Binding VersionText}" Foreground="#6c7086" FontSize="11"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding InteractionLog}" Foreground="#a6adc8" FontSize="11"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Toast 通知 -->
        <Border x:Name="ToastBorder"
                Grid.Row="0" Grid.RowSpan="3"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,60,0,0"
                Background="#313244" CornerRadius="8" Padding="16,10"
                Visibility="Collapsed" Opacity="0"
                IsHitTestVisible="False">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate" Y="-20"/>
            </Border.RenderTransform>
            <TextBlock x:Name="ToastText" Foreground="#cdd6f4" FontSize="14" TextWrapping="Wrap" MaxWidth="400"/>
        </Border>
    </Grid>
</Window>
