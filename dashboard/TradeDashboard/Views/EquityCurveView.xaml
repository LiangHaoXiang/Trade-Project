<UserControl x:Class="TradeDashboard.Views.EquityCurveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:c="clr-namespace:TradeDashboard.Converters">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <c:BoolToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- Controls -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="资金曲线与回撤" Style="{StaticResource SectionHeaderStyle}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="加载最新" Command="{Binding LoadLatestCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                <ProgressBar IsIndeterminate="{Binding IsLoading}" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" Width="100" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </DockPanel>

        <!-- Equity Curve -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
            <Grid>
                <sp:WpfPlot x:Name="EquityPlot" Background="#1a1a2e"/>
                <TextBlock x:Name="EquityPlaceholder" Text="暂无资金曲线数据，请先运行回测"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#6c7086" FontSize="13"/>
            </Grid>
        </Border>

        <!-- Drawdown -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <sp:WpfPlot x:Name="DrawdownPlot" Background="#1a1a2e"/>
                <TextBlock x:Name="DrawdownPlaceholder" Text="暂无回撤数据"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#6c7086" FontSize="13"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
