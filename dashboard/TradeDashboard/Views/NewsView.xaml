<UserControl x:Class="TradeDashboard.Views.NewsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:TradeDashboard.Converters">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:CollectionEmptyToVisibilityConverter x:Key="EmptyToVis"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
            <Button Content="刷新" Command="{Binding RefreshCommand}" Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,0"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="200" Margin="0,0,8,0"/>
            <CheckBox Content="自动刷新（30分钟）" IsChecked="{Binding AutoRefresh}" VerticalAlignment="Center" Margin="0,0,8,0"
                      Command="{Binding ToggleAutoRefreshCommand}"/>
            <TextBlock Text="{Binding NextRefreshText}" Foreground="#6c7086" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding StatusText}" Foreground="#6c7086" FontSize="12" VerticalAlignment="Center"/>
        </WrapPanel>

        <!-- News List -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <Grid>
                <!-- Loading -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <ProgressBar IsIndeterminate="True" Width="200" Margin="0,0,0,8"/>
                    <TextBlock Text="正在获取新闻..." Foreground="#6c7086" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Empty State -->
                <TextBlock Text="暂无新闻，点击刷新按钮获取"
                           Foreground="#6c7086" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding NewsItems, Converter={StaticResource EmptyToVis}}"/>

                <!-- News Items -->
                <ListBox ItemsSource="{Binding FilteredNewsItems}" SelectedItem="{Binding SelectedNewsItem}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         FontSize="13">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="0,0,0,1" BorderBrush="#313244" Padding="0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Title Row -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Title}" Foreground="#cdd6f4" FontWeight="SemiBold"
                                                   TextWrapping="Wrap" Cursor="Hand" Margin="0,0,8,0"
                                                   MouseDown="OnTitleClick"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Source}" Foreground="#89b4fa" FontSize="11"
                                                   VerticalAlignment="Top"/>
                                    </Grid>

                                    <!-- Summary -->
                                    <TextBlock Grid.Row="1" Text="{Binding Summary}" Foreground="#a6adc8" FontSize="12"
                                               TextWrapping="Wrap" Margin="0,4,0,0"
                                               MaxHeight="40" TextTrimming="CharacterEllipsis">
                                        <TextBlock.Visibility>
                                            <Binding Path="Summary" Converter="{StaticResource EmptyToVis}"/>
                                        </TextBlock.Visibility>
                                    </TextBlock>

                                    <!-- Time + Link -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding PublishedAt}" Foreground="#6c7086" FontSize="11"/>
                                        <TextBlock Text="查看原文" Foreground="#89b4fa" FontSize="11" Cursor="Hand"
                                                   Margin="12,0,0,0" MouseDown="OnLinkClick">
                                            <TextBlock.Visibility>
                                                <Binding Path="HasUrl" Converter="{StaticResource BoolToVis}"/>
                                            </TextBlock.Visibility>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Detail Panel -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,8,0,0"
                Visibility="{Binding SelectedNewsItem.HasUrl, Converter={StaticResource BoolToVis}}">
            <WrapPanel>
                <TextBlock Foreground="#6c7086" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Run Text="选中: "/><Run Text="{Binding SelectedNewsItem.Title, Mode=OneWay}" Foreground="#cdd6f4"/>
                </TextBlock>
                <Button Content="在浏览器中打开" Command="{Binding OpenUrlCommand}" Style="{StaticResource ActionButtonStyle}" FontSize="12"/>
            </WrapPanel>
        </Border>
    </Grid>
</UserControl>
