<UserControl x:Class="TradeDashboard.Views.LogViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filter Bar -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="200" Margin="0,0,8,0"/>
            <ComboBox ItemsSource="{Binding LogLevels}" SelectedItem="{Binding SelectedLevel}" Width="100" Margin="0,0,8,0"/>
            <CheckBox Content="自动滚动" IsChecked="{Binding AutoScroll}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ToggleButton IsChecked="{Binding IsMonitoring}" Margin="0,0,8,0">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Content" Value="开始监控"/>
                        <Setter Property="Background" Value="#313244"/>
                        <Setter Property="Foreground" Value="#cdd6f4"/>
                        <Setter Property="Padding" Value="12,6"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMonitoring}" Value="True">
                                <Setter Property="Content" Value="停止监控"/>
                                <Setter Property="Background" Value="#ef5350"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>
            <Button Content="刷新" Command="{Binding LoadFromFileCommand}" Style="{StaticResource ActionButtonStyle}"/>
            <Button Content="清空" Command="{Binding ClearCommand}" Style="{StaticResource ActionButtonStyle}" Margin="4,0,0,0"/>
        </WrapPanel>

        <!-- Log List -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <ListBox ItemsSource="{Binding LogEntries}" SelectedItem="{Binding SelectedLogEntry}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="12">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Foreground="#6c7086"/>
                            <TextBlock Grid.Column="1" Text="{Binding Level}" FontWeight="Bold" Margin="4,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Level}" Value="ERROR">
                                                <Setter Property="Foreground" Value="#ef5350"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Level}" Value="WARNING">
                                                <Setter Property="Foreground" Value="#f9e2af"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Level}" Value="INFO">
                                                <Setter Property="Foreground" Value="#89b4fa"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Level}" Value="DEBUG">
                                                <Setter Property="Foreground" Value="#6c7086"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Column="2" Text="{Binding Message}" Foreground="#cdd6f4" TextWrapping="Wrap"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</UserControl>
