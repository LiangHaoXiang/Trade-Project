<UserControl x:Class="TradeDashboard.Views.TradingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:TradeDashboard.Converters">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <c:DecimalToColorConverter x:Key="DecToColor"/>
            <c:DirectionToBrushConverter x:Key="DirToBrush"/>
            <c:DirectionToTextConverter x:Key="DirToText"/>
            <c:StatusToTextConverter x:Key="StatusToText"/>
            <c:CollectionEmptyToVisibilityConverter x:Key="EmptyToVis"/>
            <c:BoolToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 账户概览卡片 -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,4,0">
                <StackPanel>
                    <TextBlock Text="总资产" Style="{StaticResource CardTitleStyle}"/>
                    <TextBlock Text="{Binding AccountTotalAssets, StringFormat='{}{0:N2}'}" Style="{StaticResource CardValueStyle}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="可用资金" Style="{StaticResource CardTitleStyle}"/>
                    <TextBlock Text="{Binding AccountCash, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="#cdd6f4"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="持仓市值" Style="{StaticResource CardTitleStyle}"/>
                    <TextBlock Text="{Binding AccountMarketValue, StringFormat='{}{0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="#cdd6f4"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="总盈亏" Style="{StaticResource CardTitleStyle}"/>
                    <TextBlock Text="{Binding AccountPnlPct, StringFormat='{}{0:+0.00;-0.00;0.00}%'}"
                               Foreground="{Binding AccountPnl, Converter={StaticResource DecToColor}}"
                               FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource CardStyle}" Margin="4,0,0,0">
                <StackPanel>
                    <TextBlock Text="持仓数" Style="{StaticResource CardTitleStyle}"/>
                    <TextBlock Text="{Binding AccountPositionCount}" Style="{StaticResource CardValueStyle}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 下方：下单面板 + 持仓/委托 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左：下单面板 -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,8">
                <StackPanel Margin="0,8,12,8">
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="{Binding ModeLabel}" Style="{StaticResource SectionHeaderStyle}"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding BrokerStatusText}" Foreground="#a6adc8" FontSize="11"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Visibility="{Binding IsLiveMode, Converter={StaticResource BoolToVis}}"/>
                    </Grid>

                    <TextBlock Text="股票代码" Foreground="#a6adc8" Margin="0,8,0,4"/>
                    <TextBox Text="{Binding OrderSymbol}" FontSize="14"/>

                    <TextBlock Text="方向" Foreground="#a6adc8" Margin="0,8,0,4"/>
                    <ComboBox SelectedValue="{Binding OrderDirection}" SelectedValuePath="Tag" FontSize="14"
                              Foreground="{Binding OrderDirection, Converter={StaticResource DirToBrush}}">
                        <ComboBoxItem Content="买入" Tag="BUY"/>
                        <ComboBoxItem Content="卖出" Tag="SELL"/>
                    </ComboBox>

                    <TextBlock Text="价格" Foreground="#a6adc8" Margin="0,8,0,4"/>
                    <TextBox Text="{Binding OrderPrice, StringFormat='{}{0:N2}'}" FontSize="14"/>

                    <TextBlock Text="数量（股）" Foreground="#a6adc8" Margin="0,8,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding OrderVolume}" FontSize="14"/>
                        <Button Grid.Column="1" Content="全仓" Command="{Binding FillMaxVolumeCommand}"
                                Click="OnFillMaxVolumeClick"
                                Style="{StaticResource ActionButtonStyle}" Margin="4,0,0,0" Padding="8,4"/>
                    </Grid>

                    <Button Content="提交委托"
                            Command="{Binding SubmitOrderCommand}"
                            Click="OnSubmitOrderClick"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,16,0,0" Height="36"/>

                    <TextBlock Text="{Binding OrderMessage}" Foreground="#a6adc8" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>

                    <Separator Margin="0,16,0,8" Background="#313244"/>

                    <Grid>
                        <Button Content="重置模拟账户"
                                Command="{Binding ResetAccountCommand}"
                                Click="OnResetAccountClick"
                                Style="{StaticResource ActionButtonStyle}"
                                HorizontalAlignment="Stretch" FontSize="12"
                                Visibility="{Binding CanReset, Converter={StaticResource BoolToVis}}"/>
                        <StackPanel Visibility="{Binding IsLiveMode, Converter={StaticResource BoolToVis}}">
                            <Button Content="连接券商"
                                    Command="{Binding ConnectLiveCommand}"
                                    Click="OnConnectLiveClick"
                                    Style="{StaticResource ActionButtonStyle}"
                                    HorizontalAlignment="Stretch" FontSize="12" Margin="0,0,0,4"/>
                            <Button Content="断开连接"
                                    Command="{Binding DisconnectLiveCommand}"
                                    Click="OnDisconnectLiveClick"
                                    Style="{StaticResource ActionButtonStyle}"
                                    HorizontalAlignment="Stretch" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 右：持仓 + 委托 -->
            <TabControl Grid.Column="1">
                <TabItem Header="当前持仓">
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <DataGrid ItemsSource="{Binding Positions}" SelectedItem="{Binding SelectedPosition}"
                                      ColumnWidth="*">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="代码" Binding="{Binding Symbol}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="6,3"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="持仓量" Binding="{Binding Volume, StringFormat='{}{0:N0}'}" Width="75">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="Margin" Value="6,3"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="可用" Binding="{Binding AvailableVolume, StringFormat='{}{0:N0}'}" Width="75">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="Margin" Value="6,3"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="成本价" Binding="{Binding CostPrice, StringFormat='{}{0:N2}'}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="Margin" Value="6,3"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="现价" Binding="{Binding CurrentPrice, StringFormat='{}{0:N2}'}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="Margin" Value="6,3"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="市值" Binding="{Binding MarketValue, StringFormat='{}{0:N2}'}" Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="Margin" Value="6,3"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="盈亏" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Pnl, StringFormat='{}{0:+#,##0.00;-#,##0.00;0.00}'}"
                                                           Foreground="{Binding Pnl, Converter={StaticResource DecToColor}}"
                                                           FontWeight="Bold" TextAlignment="Right" Margin="6,3"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="盈亏%" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding PnlPct, StringFormat='{}{0:+0.00;-0.00}%'}"
                                                           Foreground="{Binding PnlPct, Converter={StaticResource DecToColor}}"
                                                           FontWeight="Bold" TextAlignment="Right" Margin="6,3"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="暂无持仓" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#6c7086" FontSize="13"
                                       Visibility="{Binding Positions, Converter={StaticResource EmptyToVis}}"/>
                        </Grid>
                    </Border>
                </TabItem>
                <TabItem Header="今日委托">
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <DataGrid ItemsSource="{Binding TodayOrders}" ColumnWidth="*">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="时间" Binding="{Binding OrderTime, StringFormat='{}{0:HH:mm:ss}'}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="6,3"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="代码" Binding="{Binding Symbol}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="6,3"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="方向" Width="60">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Direction, Converter={StaticResource DirToText}}"
                                                           Foreground="{Binding Direction, Converter={StaticResource DirToBrush}}"
                                                           FontWeight="Bold" TextAlignment="Center" Margin="6,3"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="价格" Binding="{Binding Price, StringFormat='{}{0:N2}'}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="Margin" Value="6,3"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="数量" Binding="{Binding Volume, StringFormat='{}{0:N0}'}" Width="70">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="Margin" Value="6,3"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="金额" Binding="{Binding Amount, StringFormat='{}{0:N2}'}" Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Right"/>
                                                <Setter Property="Margin" Value="6,3"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="状态" Binding="{Binding Status, Converter={StaticResource StatusToText}}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="6,3"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="原因" Binding="{Binding Reason}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Margin" Value="6,3"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="暂无委托记录" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#6c7086" FontSize="13"
                                       Visibility="{Binding TodayOrders, Converter={StaticResource EmptyToVis}}"/>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
