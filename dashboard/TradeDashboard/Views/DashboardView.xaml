<UserControl x:Class="TradeDashboard.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:c="clr-namespace:TradeDashboard.Converters">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <c:DecimalToColorConverter x:Key="DecToColor"/>
            <c:DirectionToTextConverter x:Key="DirToText"/>
            <c:DirectionToBrushConverter x:Key="DirToBrush"/>
            <c:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <c:StatusToTextConverter x:Key="StatusToText"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Summary Cards -->
        <UniformGrid Columns="4" Grid.Row="0" Margin="0,0,0,16">
            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="总资产" Style="{StaticResource CardTitleStyle}"/>
                    <TextBlock Text="{Binding TotalValue, StringFormat='{}{0:N2}'}" Style="{StaticResource CardValueStyle}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="总盈亏" Style="{StaticResource CardTitleStyle}"/>
                    <TextBlock Text="{Binding TotalPnl, StringFormat='{}{0:+#,##0.00;-#,##0.00;0.00}'}"
                               Foreground="{Binding TotalPnl, Converter={StaticResource DecToColor}}"
                               FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="收益率" Style="{StaticResource CardTitleStyle}"/>
                    <TextBlock Text="{Binding PnlPercent, StringFormat='{}{0:+0.00;-0.00;0.00}%'}"
                               Foreground="{Binding PnlPercent, Converter={StaticResource DecToColor}}"
                               FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="交易次数" Style="{StaticResource CardTitleStyle}"/>
                    <TextBlock Text="{Binding TradeCount}" Style="{StaticResource CardValueStyle}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Bottom: Recent Trades + Mini Chart -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Recent Trades -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnDashBacktest" Content="回测交易"
                                    Click="OnDashBacktestClick"
                                    Style="{StaticResource PrimaryButtonStyle}" FontSize="11" Padding="8,2"/>
                            <Button x:Name="BtnDashSim" Content="模拟盘交易"
                                    Click="OnDashSimClick"
                                    Style="{StaticResource ActionButtonStyle}" FontSize="11" Padding="8,2" Margin="2,0,0,0"/>
                        </StackPanel>
                        <Button Content="清空" Command="{Binding ClearRecentTradesCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                HorizontalAlignment="Right" FontSize="11" Padding="8,2"/>
                    </DockPanel>

                    <!-- Backtest trades DataGrid -->
                    <DataGrid ItemsSource="{Binding RecentTrades}" ColumnWidth="*"
                              HeadersVisibility="Column"
                              Visibility="{Binding IsBacktestMode, Converter={StaticResource BoolToVis}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="日期" Binding="{Binding TradeDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="85">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="4,2"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="代码" Binding="{Binding Symbol}" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="4,2"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="方向" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Direction, Converter={StaticResource DirToText}}"
                                                   Foreground="{Binding Direction, Converter={StaticResource DirToBrush}}"
                                                   FontWeight="Bold" TextAlignment="Center" Margin="4,2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="价格" Binding="{Binding Price, StringFormat='{}{0:N2}'}" Width="65">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="Margin" Value="4,2"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="数量" Binding="{Binding Volume, StringFormat='{}{0:N0}'}" Width="55">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="Margin" Value="4,2"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Sim trades DataGrid -->
                    <DataGrid ItemsSource="{Binding RecentSimOrders}" ColumnWidth="*">
                        <DataGrid.Style>
                            <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBacktestMode}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Style>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="日期" Binding="{Binding OrderTime, StringFormat='{}{0:yyyy-MM-dd}'}" Width="85">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="4,2"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="代码" Binding="{Binding Symbol}" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="4,2"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="方向" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Direction, Converter={StaticResource DirToText}}"
                                                   Foreground="{Binding Direction, Converter={StaticResource DirToBrush}}"
                                                   FontWeight="Bold" TextAlignment="Center" Margin="4,2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="价格" Binding="{Binding Price, StringFormat='{}{0:N2}'}" Width="65">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="Margin" Value="4,2"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="数量" Binding="{Binding Volume, StringFormat='{}{0:N0}'}" Width="55">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="Margin" Value="4,2"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Equity Chart -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <DockPanel>
                        <TextBlock Text="资金曲线" Style="{StaticResource SectionHeaderStyle}" DockPanel.Dock="Top"/>
                        <sp:WpfPlot x:Name="EquityPlot" Background="#1a1a2e"/>
                    </DockPanel>
                    <Canvas IsHitTestVisible="False">
                        <Border x:Name="EquityTooltip" Visibility="Collapsed"
                                Background="#2a2a3e" CornerRadius="4" Padding="10,6"
                                BorderBrush="#505070" BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="EqTipDate" Foreground="White" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="资金量" Foreground="#888" FontSize="11"/>
                                    <TextBlock Grid.Column="1" x:Name="EqTipEquity" Foreground="#89b4fa" FontSize="11" Margin="6,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Canvas>
                    <TextBlock x:Name="EquityPlaceholder" Text="暂无数据，请先运行回测"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#6c7086" FontSize="13"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
